# Database Configuration
POSTGRES_USER=apirentuser
POSTGRES_PASSWORD=apirentpass
POSTGRES_DB=apirental
DATABASE_URL=postgresql://apirentuser:apirentpass@localhost:5432/apirental

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Admin Credentials
ADMIN_EMAIL=admin@apirental.com
ADMIN_PASSWORD=admin123

# API Provider Keys (comma-separated for key pools)
OPENAI_API_KEYS=sk-openai-key-1,sk-openai-key-2,sk-openai-key-3
GEMINI_API_KEYS=gemini-key-1,gemini-key-2,gemini-key-3
ANTHROPIC_API_KEYS=sk-ant-key-1,sk-ant-key-2,sk-ant-key-3

# Cashfree Payment Gateway
# Get credentials from: https://merchant.cashfree.com/merchants/developers
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_ENVIRONMENT=sandbox
# CASHFREE_ENVIRONMENT=production  # Uncomment for production

# Email Notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@apirental.dev
ADMIN_NOTIFICATION_EMAIL=admin@apirental.dev

# Cost Estimation
PRE_REQUEST_COST_CHECK=true
COST_ESTIMATION_BUFFER=1.2

# Semantic Caching
SEMANTIC_CACHE_ENABLED=true
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_SECONDS=300

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# Spending Alerts
SPENDING_ALERT_THRESHOLD_USD=5.00
SPENDING_ALERT_WINDOW_MINUTES=10

# Drain Rates (credits per second)
DRAIN_RATE_GPT4O=10
DRAIN_RATE_CLAUDE35=8
DRAIN_RATE_GPT4O_MINI=3
DRAIN_RATE_GEMINI_FLASH=1

# PII Masking
PII_MASKING_ENABLED=true
PII_MASK_EMAILS=true
PII_MASK_PHONES=true
PII_MASK_SSNS=true
PII_MASK_CREDIT_CARDS=true

# Cost Protection
COST_PROTECTION_THRESHOLD=0.90

# Application
APP_NAME=AI API Rental SaaS
APP_VERSION=1.0.0
ENVIRONMENT=development
